# Copy to .env.local (local dev) or set in your host's env (Render) and fill in.
# Without the social vars the site silently serves placeholder content —
# monitor /api/social/health to catch an expired token.

# --- Social hydration (Facebook + Instagram via the Graph API) ---
# Facebook Page ID and a long-lived Page access token.
FB_PAGE_ID=
FB_ACCESS_TOKEN=
# Instagram Business/Creator account ID (linked to the same FB app/token).
IG_USER_ID=
# NOTE: long-lived tokens expire ~every 60 days — refresh before they lapse.

# --- Call-to-action links ---
# Real donation page (Givebutter / Zeffy / PayPal). If unset, the Donate
# buttons fall back to the on-page contact section.
NEXT_PUBLIC_DONATE_URL=
